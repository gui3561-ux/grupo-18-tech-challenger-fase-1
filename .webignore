# Azure App Service ignore file
# Arquivos e diretórios a serem ignorados durante o deploy

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Ambiente virtual
.venv/
venv/
env/
ENV/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Documentação
docs/
*.md
LICENSE
README.md
CHANGELOG.md

# Dados e notebooks
data/
notebooks/
*.ipynb
*.ipynb_checkpoints/

# MLFlow tracking
mlflow_tracking/

# Modelos alternativos (manter apenas neural_network)
models/gradient_boosting_pipeline.pkl
models/knn_pipeline.pkl
models/logistic_regression_pipeline.pkl
models/random_forest_pipeline.pkl
models/svm_pipeline.pkl
models/xgboost_pipeline.pkl
models/lightgbm_pipeline.pkl

# Scripts de desenvolvimento
scripts/post_deploy_cleanup.sh
utils/

# Configurações locais
.env
*.env
.env.local
.env.*.local

# Logs
logs/
*.log

# Testes (opcional - manter se quiser rodar testes no Azure)
# tests/

# Arquivos temporários
tmp/
temp/
*.tmp
*.temp

# Build artifacts
dist/
build/
*.egg-info/

# Sistema
.DS_Store
Thumbs.db

# Azure specific
.deployment
deploy.cmd
deploy.sh
deploy.zip
deploy_package/

# Model Card
MODEL_CARD.md

# Web ignore próprio (para evitar recursão)
.webignore