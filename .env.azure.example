# Configurações de ambiente para Azure App Service
# Copie para .env.azure e ajuste conforme necessário

# Configurações da API
API_TITLE="Churn Prediction API"
API_DESCRIPTION="API de inferência para o modelo de predição de churn de clientes usando Neural Network"
API_VERSION="1.0.0"

# Caminho do modelo (relativo à raiz do projeto no Azure)
MODEL_PATH="models/neural_network_pipeline.pkl"

# Nível de log
LOG_LEVEL="INFO"

# Thresholds para classificação de risco
RISK_THRESHOLD_LOW=0.3
RISK_THRESHOLD_MEDIUM=0.6

# Configurações de monitoramento
PROMETHEUS_METRICS_ENABLED=true
APPLICATIONINSIGHTS_ENABLED=true

# Configurações do Azure (serão definidas como App Settings)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
# WEBSITE_PROMETHEUS_SCRAPE_ENDPOINT=/api/v1/metrics/
# WEBSITE_PROMETHEUS_PORT=8001

# Configurações do servidor
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
HOST=0.0.0.0
PORT=8000
TIMEOUT=300

# Nota: No Azure App Service, as variáveis de ambiente são configuradas como:
# 1. Application Settings no portal Azure
# 2. Ou via Azure CLI: az webapp config appsettings set ...

# Para configurar via CLI:
# az webapp config appsettings set \
#   --name churn-prediction-api \
#   --resource-group rg-churn-api \
#   --settings \
#   MODEL_PATH="models/neural_network_pipeline.pkl" \
#   LOG_LEVEL="INFO" \
#   API_TITLE="Churn Prediction API" \
#   APPLICATIONINSIGHTS_CONNECTION_STRING="InstrumentationKey=..." \
#   WEBSITE_PROMETHEUS_SCRAPE_ENDPOINT="/api/v1/metrics/" \
#   WEBSITE_PROMETHEUS_PORT="8001"